{
  "code": "edu.enrollment.group",
  "title": "School Application & Group Enrollment",
  "context_scope": [
    "organisation",
    "student",
    "class_group"
  ],
  "triggers": [
    "school_application_submit",
    "staff_enroll_submit",
    "placement_recommendation_accept"
  ],
  "steps": [
    {
      "id": "application_review",
      "title": "Review school application",
      "group": "Admissions",
      "actor_role": "reception",
      "optional": false,
      "execution": "manual",
      "inputs": [
        {
          "name": "application_id",
          "type": "string",
          "required": true
        },
        {
          "name": "decision",
          "type": "enum",
          "options": [
            "approved",
            "waitlist",
            "rejected"
          ],
          "required": true
        },
        {
          "name": "decision_note",
          "type": "string",
          "required": false
        }
      ],
      "outputs": [
        {
          "name": "application_status",
          "type": "enum",
          "options": [
            "approved",
            "waitlist",
            "rejected"
          ]
        }
      ],
      "actions": [
        {
          "type": "admissions.set_status",
          "args": {
            "status_var": "decision"
          }
        }
      ],
      "decorators": []
    },
    {
      "id": "collect",
      "title": "Collect enrollment details",
      "group": "Enrollment",
      "actor_role": "reception",
      "optional": false,
      "execution": "manual",
      "inputs": [
        {
          "name": "student_id",
          "type": "relation:Student",
          "required": true
        },
        {
          "name": "class_group_id",
          "type": "relation:ClassGroup",
          "required": true
        },
        {
          "name": "start_date",
          "type": "date",
          "required": true
        }
      ],
      "outputs": [
        {
          "name": "enrollment_id",
          "type": "relation:Enrollment"
        }
      ],
      "actions": [
        {
          "type": "workflow.guard",
          "args": {
            "when": "application_status == 'approved'"
          }
        },
        {
          "type": "class.enroll_student",
          "args": {}
        }
      ],
      "decorators": []
    },
    {
      "id": "contract",
      "title": "Generate & send contract",
      "group": "Documents",
      "actor_role": "system",
      "optional": false,
      "execution": "auto",
      "inputs": [],
      "outputs": [],
      "actions": [
        {
          "type": "documents.generate",
          "args": {
            "template": "doc.contract.school_parent"
          }
        },
        {
          "type": "signature.request",
          "args": {
            "profile": "XAdES_BASIC"
          }
        }
      ],
      "decorators": []
    },
    {
      "id": "bill",
      "title": "Create invoice / schedule",
      "group": "Billing",
      "actor_role": "system",
      "optional": false,
      "execution": "auto",
      "inputs": [],
      "outputs": [],
      "actions": [
        {
          "type": "billing.create_term_schedule",
          "args": {
            "product": "prod.term.fee"
          }
        }
      ],
      "decorators": []
    },
    {
      "id": "notify",
      "title": "Notify parent & teacher",
      "group": "Comms",
      "actor_role": "system",
      "optional": false,
      "execution": "auto",
      "inputs": [],
      "outputs": [],
      "actions": [
        {
          "type": "comms.send",
          "args": {
            "template": "doc.weekly_digest",
            "mode": "enrollment_welcome"
          }
        }
      ],
      "decorators": []
    }
  ]
}
