    "Install the suite",
    "Connect calendar and payments",
    "Import students and launch lessons"
  ],
  "demo": {
    "video": "/static/demos/language-teaching-suite.mp4",
    "length_sec": 90
  },
  "arch_diagram": "/static/diagrams/language-teaching-suite-architecture.png",
  "min_rc_version": "2025.1",
  "modules_required": [
    "CRM",
    "Calendar",
    "Documents",
    "Finance",
    "Store",
    "BPM",
    "AI",
    "Communication",
    "HR"
  ],
  "on_install": {
    "run_workflows": [
      "edu.onboarding.seed_defaults"
    ],
    "create_policies": [
      "policies/tutor_default.json",
      "policies/school_default.json"
    ],
    "create_products": [
      "products/bundle-10x45.json",
      "products/bundle-10x60.json",
      "products/dropin-90.json",
      "products/subscription-monthly.json",
      "products/term-fee.json"
    ],
    "register_documents": [
      "documents/templates/lesson_recap.json",
      "documents/templates/weekly_digest.json",
      "documents/templates/contract_tutor_parent.json",
      "documents/templates/contract_school_parent.json",
      "documents/templates/lesson_reminder_sms.json",
      "documents/templates/lesson_reminder_whatsapp.json",
      "documents/templates/progress_report.json",
      "documents/templates/enrollment_certificate.json"
    ],
    "register_dashboards": [
      "dashboards/default.json"
    ]
  },
  "on_uninstall": {
    "cleanup": true
  },
  "permissions": {
    "scopes": [
      "edu:view",
      "edu:manage",
      "edu:billing",
      "edu:teacher",
      "edu:reception"
